{"openapi":"3.1.0","info":{"title":"Presentation Generator API","description":"REST API for generating and editing slides.\n\n**Template-free flow:** generate-outline → edit-outline → approve → edit\n\n**Template-based flow:** generate-from-template → edit","version":"1.0.0"},"paths":{"/api/outline/generate":{"post":{"tags":["Template-Free Flow"],"summary":"שלב 1 (ללא תבנית): יצירת מבנה מוצע","description":"Generate a proposed presentation outline from a user prompt and optional document.\nReturns an outline for review — call `/outline/approve` to generate the actual content.","operationId":"api_generate_outline_api_outline_generate_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/GenerateOutlineRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/OutlineResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/outline/edit":{"put":{"tags":["Template-Free Flow"],"summary":"שלב 2 (אופציונלי): עריכת המבנה המוצע","description":"Edit the proposed outline before approving it.\nFor example: \"הוסף שקף על לוחות זמנים\" or \"הסר את שקף 3\".","operationId":"api_edit_outline_api_outline_edit_put","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/EditOutlineRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/OutlineResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/outline/approve":{"post":{"tags":["Template-Free Flow"],"summary":"שלב 3: אישור מבנה ויצירת תוכן","description":"Approve the current outline and generate full slide content.\nConverts the outline to a skeleton and runs SlideAgent on every slide.","operationId":"api_approve_outline_api_outline_approve_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DeckResponse"}}}}}}},"/api/deck/generate":{"post":{"tags":["Template-Based Flow"],"summary":"יצירת מצגת מתבנית","description":"Generate slide content from a pre-built skeleton template (JSON).\nSkips the outline step entirely — goes straight to content generation.","operationId":"api_generate_from_template_api_deck_generate_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/GenerateFromTemplateRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DeckResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/deck/edit":{"put":{"tags":["Editing"],"summary":"עריכת מצגת שלמה","description":"Apply a natural-language edit across the entire deck.\nFor example: \"הפוך את כל המצגת לפורמלית יותר\" or \"קצר את כל השקפים\".","operationId":"api_edit_deck_api_deck_edit_put","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/DeckEditRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/EditResultResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/slide/{slide_num}/edit":{"put":{"tags":["Editing"],"summary":"עריכת שקף בודד","description":"Apply a natural-language edit to a specific slide.\nFor example: \"עדכן את Content 1 עם תאריך האירוע\" or \"שנה layout לשתי עמודות\".","operationId":"api_edit_slide_api_slide__slide_num__edit_put","parameters":[{"name":"slide_num","in":"path","required":true,"schema":{"type":"integer","title":"Slide Num"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/SlideEditRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/EditResultResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/deck/export":{"get":{"tags":["Utility"],"summary":"ייצוא המצגת הנוכחית","description":"Return the current deck JSON.","operationId":"api_export_deck_api_deck_export_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DeckResponse"}}}}}}},"/api/revisions":{"get":{"tags":["Utility"],"summary":"רשימת גרסאות","description":"List all saved revisions for the current session.","operationId":"api_list_revisions_api_revisions_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/RevisionsListResponse"}}}}}}},"/api/revisions/{revision_id}/restore":{"put":{"tags":["Utility"],"summary":"שחזור גרסה","description":"Restore the deck to a previous revision.","operationId":"api_restore_revision_api_revisions__revision_id__restore_put","parameters":[{"name":"revision_id","in":"path","required":true,"schema":{"type":"integer","title":"Revision Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/RestoreResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}}},"components":{"schemas":{"DeckEditRequest":{"properties":{"user_message":{"type":"string","title":"User Message","description":"הנחיית עריכה, לדוגמה: \"הפוך את כל המצגת לפורמלית יותר\""}},"type":"object","required":["user_message"],"title":"DeckEditRequest","description":"Edit the entire deck via a natural-language instruction."},"DeckResponse":{"properties":{"status":{"type":"string","title":"Status"},"slide_count":{"type":"integer","title":"Slide Count"},"revision_id":{"type":"integer","title":"Revision Id"},"deck":{"additionalProperties":true,"type":"object","title":"Deck"}},"type":"object","required":["status","slide_count","revision_id","deck"],"title":"DeckResponse","description":"Returned after generating, approving, or editing a full deck."},"EditOutlineRequest":{"properties":{"edit_instruction":{"type":"string","title":"Edit Instruction","description":"בקשת שינוי, לדוגמה: \"הוסף שקף על לוחות זמנים\""}},"type":"object","required":["edit_instruction"],"title":"EditOutlineRequest","description":"Template-free flow — step 2 (optional): edit the proposed outline before approval."},"EditResultResponse":{"properties":{"status":{"type":"string","title":"Status"},"applied_count":{"type":"integer","title":"Applied Count"},"summary":{"type":"string","title":"Summary"},"revision_id":{"type":"integer","title":"Revision Id"},"deck":{"additionalProperties":true,"type":"object","title":"Deck"}},"type":"object","required":["status","applied_count","summary","revision_id","deck"],"title":"EditResultResponse","description":"Returned after a deck-level or slide-level edit."},"GenerateFromTemplateRequest":{"properties":{"template":{"additionalProperties":true,"type":"object","title":"Template","description":"JSON skeleton של התבנית (כולל slides)"},"user_prompt":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"User Prompt","description":"הנחיית משתמש (אופציונלי)","default":""},"document_text":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Document Text","description":"טקסט מסמך מקור (אופציונלי)","default":""}},"type":"object","required":["template"],"title":"GenerateFromTemplateRequest","description":"Template-based flow — step 1: upload a skeleton template and generate content."},"GenerateOutlineRequest":{"properties":{"user_prompt":{"type":"string","title":"User Prompt","description":"הנחיית המשתמש (נדרש)"},"document_text":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Document Text","description":"טקסט מסמך מקור (אופציונלי)","default":""},"slide_count":{"anyOf":[{"type":"integer","maximum":30.0,"minimum":1.0},{"type":"null"}],"title":"Slide Count","description":"מספר שקפים מבוקש (None = אוטומטי)"}},"type":"object","required":["user_prompt"],"title":"GenerateOutlineRequest","description":"Template-free flow — step 1: generate a proposed outline.","examples":[{"document_text":"...","slide_count":5,"user_prompt":"מצגת על חקירת אירוע טיסת חירום"}]},"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"OutlineResponse":{"properties":{"status":{"type":"string","title":"Status"},"slide_count":{"type":"integer","title":"Slide Count"},"outline":{"additionalProperties":true,"type":"object","title":"Outline"},"content_warning":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Content Warning"}},"type":"object","required":["status","slide_count","outline"],"title":"OutlineResponse","description":"Returned after generating or editing an outline."},"RestoreResponse":{"properties":{"status":{"type":"string","title":"Status"},"revision_id":{"type":"integer","title":"Revision Id"},"deck":{"additionalProperties":true,"type":"object","title":"Deck"}},"type":"object","required":["status","revision_id","deck"],"title":"RestoreResponse"},"RevisionInfo":{"properties":{"revision_id":{"type":"integer","title":"Revision Id"},"timestamp":{"type":"string","title":"Timestamp"},"action":{"type":"string","title":"Action"},"description":{"type":"string","title":"Description"}},"type":"object","required":["revision_id","timestamp","action","description"],"title":"RevisionInfo"},"RevisionsListResponse":{"properties":{"revisions":{"items":{"$ref":"#/components/schemas/RevisionInfo"},"type":"array","title":"Revisions"}},"type":"object","required":["revisions"],"title":"RevisionsListResponse"},"SlideEditRequest":{"properties":{"user_message":{"type":"string","title":"User Message","description":"הנחיית עריכה, לדוגמה: \"עדכן את Content 1 עם תאריך האירוע\""}},"type":"object","required":["user_message"],"title":"SlideEditRequest","description":"Edit a single slide via a natural-language instruction."},"ValidationError":{"properties":{"loc":{"items":{"anyOf":[{"type":"string"},{"type":"integer"}]},"type":"array","title":"Location"},"msg":{"type":"string","title":"Message"},"type":{"type":"string","title":"Error Type"}},"type":"object","required":["loc","msg","type"],"title":"ValidationError"}}}}